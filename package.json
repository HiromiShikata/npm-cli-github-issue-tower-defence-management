{
  "name": "github-issue-tower-defence-management",
  "version": "1.117.4",
  "description": "",
  "main": "bin/index.js",
  "scripts": {
    "prebuild": "npm run doctor && npm run build:console-ui",
    "doctor:node-version": "check-node-version --node 24 --npx 11 --npm 11",
    "doctor": "npm run doctor:node-version",
    "prettier": "prettier --write '**/*'",
    "lint": "eslint src",
    "lint-fix": "eslint src --fix",
    "fmt": "npm run prettier && npm run lint-fix",
    "build:console-ui": "vite build --config src/adapter/entry-points/console/ui/vite.config.ts",
    "build": "tsc -p ./tsconfig.build.json",
    "postbuild": "node scripts/copyConsoleUiDist.mjs",
    "console-ui:lint": "biome check src/adapter/entry-points/console/ui",
    "console-ui:e2e:typecheck": "tsc --noEmit -p src/adapter/entry-points/console/ui/e2e/tsconfig.json",
    "console-ui:e2e": "npm run build:console-ui && playwright test --config src/adapter/entry-points/console/ui/e2e/playwright.config.ts",
    "console-ui:storybook": "storybook dev -p 6006 -c src/adapter/entry-points/console/ui/.storybook",
    "console-ui:build-storybook": "storybook build -c src/adapter/entry-points/console/ui/.storybook -o src/adapter/entry-points/console/ui/storybook-static",
    "test": "jest",
    "prepare": "ts-patch install && typia patch"
  },
  "bin": {
    "github-issue-tower-defence-management": "bin/adapter/entry-points/cli/index.js"
  },
  "types": "types/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HiromiShikata/npm-cli-github-issue-tower-defence-management.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/HiromiShikata/npm-cli-github-issue-tower-defence-management/issues"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/npm",
        {
          "npmPublish": true,
          "provenance": true
        }
      ]
    ],
    "branches": [
      "main"
    ]
  },
  "homepage": "https://github.com/HiromiShikata/npm-cli-github-issue-tower-defence-management#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@playwright/test": "1.60.0",
    "@radix-ui/react-slot": "^1.2.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@storybook/react-vite": "^9.0.0",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/react": "16.3.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@eslint/js": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "typescript-eslint": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "check-node-version": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commitlint": "^21.0.0",
    "conventional-changelog-conventionalcommits": "^9.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-import-x": "^4.0.0",
    "eslint-plugin-unused-imports": "^4.0.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "jest-html-reporter": "^4.4.0",
    "jest-junit": "^17.0.0",
    "jest-mock-extended": "^4.0.0-beta1",
    "prettier": "^3.2.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "semantic-release": "^25.0.0",
    "storybook": "^9.0.0",
    "tailwind-merge": "^3.0.0",
    "tailwindcss": "^4.1.0",
    "ts-jest": "^29.1.2",
    "ts-patch": "^4.0.0",
    "typescript": "^6.0.0",
    "vite": "^6.3.0"
  },
  "dependencies": {
    "better-sqlite3": "12.10.0",
    "commander": "^14.0.0",
    "dompurify": "3.4.11",
    "dotenv": "^17.0.0",
    "gemoji": "8.1.0",
    "googleapis": "^171.4.0",
    "ky": "^2.0.0",
    "marked": "12.0.2",
    "marked-emoji": "2.0.3",
    "typia": "^12.0.0",
    "yaml": "^2.6.0"
  }
}
